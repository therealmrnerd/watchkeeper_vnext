{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://watchkeeper.local/contracts/v1/intent_sketch.schema.json",
  "title": "IntentSketch",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "intent",
    "say",
    "tool",
    "arg"
  ],
  "properties": {
    "intent": {
      "type": "string",
      "enum": [
        "respond",
        "clarify",
        "tool_request"
      ]
    },
    "say": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "tool": {
      "type": "string",
      "enum": [
        "none",
        "keypress",
        "set_lights",
        "music_next"
      ]
    },
    "arg": {
      "type": "string",
      "maxLength": 32
    }
  }
}
