    "DockingDenied": {
      "fields": ["Reason", "MarketID", "StationName", "StationName_Localised", "StationType"]
    },
    "DockingCancelled": {
      "fields": ["MarketID", "StationName", "StationName_Localised", "StationType"]
    },
    "DockingTimeout": {
      "fields": ["MarketID", "StationName", "StationName_Localised", "StationType"]
    },
    "Docked": {
      "fields": [
        "StationName", "StationName_Localised", "StationType",
        "Taxi", "Multicrew", "StarSystem", "SystemAddress",
        "MarketID", "StationFaction", "StationGovernment",
        "StationGovernment_Localised", "StationServices",
        "StationEconomy", "StationEconomy_Localised", "StationEconomies",
        "DistFromStarLS", "LandingPads", "Wanted", "ActiveFine",
        "StationAllegiance", "CockpitBreach", "StationState"
      ]
