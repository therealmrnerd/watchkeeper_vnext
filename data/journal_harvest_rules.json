    "NavRoute": {
      "fields": ["Route"]
    },
    "NavRouteClear": {
      "fields": ["Route"]
    },
    "SupercruiseEntry": {
      "fields": ["Taxi", "Multicrew", "StarSystem", "SystemAddress", "Wanted"]
    },
    "SupercruiseExit": {
      "fields": ["Taxi", "Multicrew", "StarSystem", "SystemAddress", "Body", "BodyID", "BodyType"]
